@model F1_Car_Garage.Models.Car
@{
    ViewData["Title"] = "QR Code - " + Model.Model; // QRcode cshtml page, which generates a QR code for the selected car. The QR code links to the API endpoint that provides live performance stats for the car. The page also displays the car's details and includes a button to download the QR code as an image.
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>QR Code — @Model.Model</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Cars</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card p-4 text-center">
            <h5 class="mb-3">Scan to view live performance stats</h5>
            <img src="/Car/QRCode/@Model.CarId"
                 alt="QR Code for @Model.Model"
                 class="img-fluid mx-auto"
                 style="max-width:300px" />
            <p class="text-muted mt-3" style="font-size:13px">
                Links to: /api/CarsApi/@Model.CarId/stats
            </p>
            <a href="/Car/QRCode/@Model.CarId" download="@Model.Model-QRCode.png"
               class="btn btn-danger mt-2">Download QR Code</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-4">
            <h5 class="mb-3">Car Details</h5>
            <table class="table table-sm">
                <tr>
                    <td><strong>Model</strong></td>
                    <td>@Model.Model</td>
                </tr>
                <tr>
                    <td><strong>Base Speed</strong></td>
                    <td>@Model.BaseSpeed</td>
                </tr>
                <tr>
                    <td><strong>Base Handling</strong></td>
                    <td>@Model.BaseHandling</td>
                </tr>
                <tr>
                    <td><strong>Base Acceleration</strong></td>
                    <td>@Model.BaseAcceleration</td>
                </tr>
                <tr>
                    <td><strong>Base Maneuverability</strong></td>
                    <td>@Model.BaseManeuverability</td>
                </tr>
            </table>
        </div>
    </div>
</div>