@model IEnumerable<F1_Car_Garage.Models.Manufacturer>
@{
    ViewData["Title"] = "Manufacturers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manufacturers</h2>
    <a asp-action="Create" class="btn btn-danger">+ Add Manufacturer</a>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Country</th>
            <th>Tier</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Name</td>
                <td>@m.Country</td>
                <td><span class="badge bg-secondary">@m.Tier</span></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@m.ManufacturerId"
                       class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@m.ManufacturerId"
                       class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>