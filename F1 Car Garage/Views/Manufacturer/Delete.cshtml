@model F1_Car_Garage.Models.Manufacturer
@{
    ViewData["Title"] = "Delete Manufacturer";
}

<h2>Delete Manufacturer</h2>

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.Name</strong>?
</div>

<div class="card p-3 mb-3" style="max-width:400px">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Country:</strong> @Model.Country</p>
    <p><strong>Tier:</strong> @Model.Tier</p>
</div>

<form asp-action="Delete" method="post">
    <input asp-for="ManufacturerId" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>