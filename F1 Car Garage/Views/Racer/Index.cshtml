@model IEnumerable<F1_Car_Garage.Models.Racer>
@{
    ViewData["Title"] = "Racers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Racers</h2>
    <a asp-action="Upsert" class="btn btn-danger">+ Add Racer</a>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Nationality</th>
            <th>Points</th>
            <th>Car</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Name</td>
                <td>@r.Nationality</td>
                <td><span class="badge bg-danger">@r.Points pts</span></td>
                <td>@r.Car?.Model</td>
                <td>
                    <a asp-action="Upsert" asp-route-id="@r.RacerId"
                       class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@r.RacerId"
                       class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>